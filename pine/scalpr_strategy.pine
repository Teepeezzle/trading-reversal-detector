//@version=6
// =====================================================================
// SCALPR — STRATEGY version (backtestable) · derived from the SCALPR AI
// indicator by Teepeezzle. Pine v6 · free plan.
//
// WHAT THE BACKTEST FOUND (BTC/Gold/Oil, Python replay of these exact rules):
//   * 1h LOSES on all three (expR -0.11 to -0.21). Do NOT scalp it.
//   * 4H also fails: BTC -0.07, Oil -0.32, Gold ~flat. The edge does NOT
//     survive at 4H (long-breakout went negative on BTC and Oil).
//   * DAILY is the only profitable timeframe (BTC PF 1.71, Oil 1.30, Gold ~flat).
//   * The edge is the LONG BREAKOUT (Donchian up) ON DAILY: positive on all
//     three -> BTC +0.87 expR (PF 3.31), Gold +0.48 (PF 1.94), Oil +0.10.
//   * SHORTS lose almost everywhere (shorting an uptrend) and intraday/4h
//     EMA/RSI trend-crosses get whipsawed.
//   OUT-OF-SAMPLE VALIDATED: trained on earlier years, tested on recent unseen
//   years. The DAILY long breakout HELD on all three assets (pooled OOS expR
//   +0.32R base / +0.38R with the 200-SMA macro filter; per-asset OOS PF 1.4-2.4).
//   The 200-SMA macro filter (only long above it) improved expectancy & PF.
//   Lesson from the test: do NOT optimize the Donchian length per-asset (it
//   overfit on Oil); the fixed length generalised. ~3-4 trades/asset/year, so
//   run a BASKET of assets. Defaults below = the validated config (Long
//   Breakout + macro only). Still forward-test/paper-trade before sizing up.
// =====================================================================
strategy("SCALPR [Strategy]", overlay = true, pyramiding = 0,
     default_qty_type = strategy.percent_of_equity, default_qty_value = 100,
     commission_type = strategy.commission.percent, commission_value = 0.05,
     slippage = 2, initial_capital = 10000, calc_on_every_tick = false)

// ---------------- Inputs ----------------
gE = "EMA / RSI"
emaFast = input.int(9,  "Fast EMA", group = gE)
emaSlow = input.int(21, "Slow EMA", group = gE)
rsiLen  = input.int(14, "RSI length", group = gE)
rsiOB   = input.int(80, "RSI overbought", group = gE)
rsiOS   = input.int(20, "RSI oversold", group = gE)

gR = "Risk (ATR)"
atrLen = input.int(14, "ATR length", group = gR)
slMult = input.float(1.5, "Stop (ATR x)", step = 0.1, group = gR)
tpMult = input.float(3.0, "Target (ATR x)", step = 0.1, group = gR)

gA = "Regime (ADX) / Breakout"
adxLen     = input.int(14, "ADX length", group = gA)
adxRanging = input.float(20.0, "Ranging if ADX <", group = gA)
donchLen   = input.int(20, "Breakout lookback", group = gA)
volConfirm = input.bool(false, "Require volume spike for breakout", group = gA)

gT = "Components (toggle to isolate the edge)"
enLongBO  = input.bool(true,  "Long  Breakout  (the validated edge)", group = gT)
enShortBO = input.bool(false, "Short Breakout", group = gT)
enLongTr  = input.bool(false, "Long  Trend-cross", group = gT)
enShortTr = input.bool(false, "Short Trend-cross", group = gT)

gM = "Macro filter (validated improvement)"
useMacro = input.bool(true, "Only long above 200-SMA (OOS-validated)", group = gM)
macroLen = input.int(200, "Macro SMA length", group = gM)

// ---------------- Series ----------------
ema9  = ta.ema(close, emaFast)
ema21 = ta.ema(close, emaSlow)
rsi   = ta.rsi(close, rsiLen)
atr   = ta.atr(atrLen)
[diP, diM, adx] = ta.dmi(adxLen, adxLen)

ranging = adx < adxRanging
bull = ema9 > ema21
bear = ema9 < ema21
golden = ta.crossover(ema9, ema21)
death  = ta.crossunder(ema9, ema21)
rsiUp  = ta.crossover(rsi, rsiOS)
rsiDn  = ta.crossunder(rsi, rsiOB)

dHigh = ta.highest(high, donchLen)
dLow  = ta.lowest(low, donchLen)
volSpike = volume > ta.sma(volume, 20) * 1.5

// Macro filter: only LONG above the 200-SMA (OOS-validated to lift expectancy
// and profit factor); shorts get the inverse.
sma200 = ta.sma(close, macroLen)
macroLongOK  = (not useMacro) or close > sma200
macroShortOK = (not useMacro) or close < sma200

// ---------------- Signals (faithful to the indicator) ----------------
longTrend  = enLongTr  and not ranging and bull and (rsiUp or golden) and macroLongOK
shortTrend = enShortTr and not ranging and bear and (rsiDn or death) and macroShortOK
longBO     = enLongBO  and ranging and close > dHigh[1] and macroLongOK  and (volConfirm ? volSpike : true)
shortBO    = enShortBO and ranging and close < dLow[1]  and macroShortOK and (volConfirm ? volSpike : true)

goLong  = longTrend or longBO
goShort = shortTrend or shortBO

// ---------------- Orders (one position at a time) ----------------
var float slPx = na
var float tpPx = na

if goLong and strategy.position_size == 0
    slPx := close - slMult * atr
    tpPx := close + tpMult * atr
    strategy.entry("Long", strategy.long)
if goShort and strategy.position_size == 0
    slPx := close + slMult * atr
    tpPx := close - tpMult * atr
    strategy.entry("Short", strategy.short)

if strategy.position_size > 0
    strategy.exit("L-exit", from_entry = "Long", stop = slPx, limit = tpPx)
if strategy.position_size < 0
    strategy.exit("S-exit", from_entry = "Short", stop = slPx, limit = tpPx)

// ---------------- Visuals ----------------
plot(ema9,  "EMA fast", color.new(color.orange, 0))
plot(ema21, "EMA slow", color.new(color.purple, 0))
plot(strategy.position_size != 0 ? slPx : na, "SL", color.red,   1, plot.style_linebr)
plot(strategy.position_size != 0 ? tpPx : na, "TP", color.green, 1, plot.style_linebr)
plotshape(longBO,  "LongBO",  shape.triangleup,   location.belowbar, color.aqua,    size = size.tiny)
plotshape(shortBO, "ShortBO", shape.triangledown, location.abovebar, color.fuchsia, size = size.tiny)
