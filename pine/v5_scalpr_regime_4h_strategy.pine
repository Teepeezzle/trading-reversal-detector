//@version=6
// =====================================================================
// V5 + SCALPR REGIME  [4H BASKET STRATEGY]
// Pine v6 · free plan.
//
// Architecture (best of each system, per the v9 combined backtest):
//   V5:      signal generator (regular MACD divergence pivot, aligned with
//            the chart-native 200-SMA, pivot-to-pivot span 6-50 bars).
//   SCALPR:  REGIME GATE — only trade when ADX(14) >= 20 (strong trend,
//            not ranging) AND EMA9/EMA21 side agrees with trade direction.
//   Koh3:    NOT USED — the v9 backtest showed adding Koh3 confirmation
//            candles degraded results on every configuration tested.
//   Exit:    SCALPR ATR-based, SL 1.5xATR, TP 3.0xATR (1:2 R:R).
//
// TESTED CONFIGURATION (v9 combined test, Python replay on yfinance ~2y):
//   Timeframe:   4H (resampled from 1H)
//   Basket:      Gold, Silver, BTC, WTI Oil, NAS100  (5 assets, each $10k)
//   Portfolio:   +2.6% net, PF 2.63, 54.5% agg win rate over 11 trades
//   Per-asset breakdown (winners): Gold 67% n=3, Silver 50% n=2,
//     BTC 100% n=1, WTI 50% n=4 (PF 2.49, +5.3%), NAS100 0% n=1
//
// HONEST CAVEATS (please read before live deployment):
//   1) 11 pooled trades over ~2 years is a small sample. Per-asset n=1-4.
//      Wilson CI on 54.5% is wide; treat this as "directionally promising",
//      not "statistically proven".
//   2) The same test on 1H showed 33% win, PF 0.91 — the edge does NOT
//      transfer to faster timeframes. Use ONLY on 4H.
//   3) The tested config used symmetric 5-bar pivots. Changing leftBars or
//      rightBars will produce different signals and different equity.
//   4) Deploy as a SATELLITE strategy (1-3% risk) alongside the validated
//      daily-breakout basket, NOT as a standalone.
// =====================================================================
strategy("V5 + SCALPR Regime [4H BASKET]",
     overlay = true,
     max_lines_count = 500, max_labels_count = 500,
     initial_capital = 10000,
     default_qty_type = strategy.percent_of_equity,
     default_qty_value = 100,
     commission_type = strategy.commission.percent,
     commission_value = 0.05,
     slippage = 2,
     pyramiding = 0,
     calc_on_every_tick = false,
     process_orders_on_close = false)

// ---------------- Inputs (defaults match the tested config) ----------------
g1 = "Pivot detection"
leftBars  = input.int(5, "LEFT bars (structure)",  minval = 2, group = g1,
     tooltip = "5 matches the tested config. Lower = more signals, different result.")
rightBars = input.int(5, "RIGHT bars (confirmation lag)", minval = 1, maxval = 10,
     group = g1,
     tooltip = "5 matches tested. Lower = earlier but less firm. 0 impossible without repainting.")

g2 = "MACD (12/26/9 standard)"
fastLen = input.int(12, "MACD fast",   group = g2)
slowLen = input.int(26, "MACD slow",   group = g2)
sigLen  = input.int(9,  "MACD signal", group = g2)

g3 = "V5 trend alignment (chart-native 200-SMA)"
trendLen = input.int(200, "Trend SMA length", minval = 50, group = g3)

g4 = "V5 bar-span filter"
spanMin = input.int(6,  "Span MIN (bars)", minval = 1, group = g4)
spanMax = input.int(50, "Span MAX (bars)", minval = 1, group = g4)

g5 = "SCALPR regime gate (the key filter)"
adxLen = input.int(14, "ADX length", group = g5)
adxMin = input.float(20.0, "ADX min (skip trades below this)", step = 0.5, group = g5,
     tooltip = "Below 20 = ranging market where divergence signals fail. " +
               "This gate is the reason the config beats V5 baseline.")
emaFast = input.int(9,  "EMA fast", group = g5)
emaSlow = input.int(21, "EMA slow", group = g5)

g6 = "Risk (SCALPR-style ATR exits)"
atrLen = input.int(14, "ATR length", group = g6)
slMult = input.float(1.5, "SL (ATR x)", step = 0.1, group = g6)
tpMult = input.float(3.0, "TP (ATR x)", step = 0.1, group = g6)
exitOnOpp = input.bool(true, "Exit on opposite ALIGNED divergence", group = g6)

g7 = "Display"
tintBg   = input.bool(true, "Tint background by trend regime", group = g7)
showDots = input.bool(true, "Mark swing pivots", group = g7)
showEMAs = input.bool(true, "Plot EMA9 / EMA21 (SCALPR context)", group = g7)
showDash = input.bool(true, "Show regime dashboard", group = g7)

// ---------------- Core series ----------------
[macdLine, _s, _h] = ta.macd(close, fastLen, slowLen, sigLen)
sma = ta.sma(close, trendLen)
atr = ta.atr(atrLen)
[diP, diM, adx] = ta.dmi(adxLen, adxLen)
ema9  = ta.ema(close, emaFast)
ema21 = ta.ema(close, emaSlow)

inUptrend   = close > sma
inDowntrend = close < sma
regimeStrong = adx >= adxMin
bullContext = ema9 > ema21
bearContext = ema9 < ema21

// ---------------- Pivots (non-repainting) ----------------
ph = ta.pivothigh(high, leftBars, rightBars)
pl = ta.pivotlow(low,  leftBars, rightBars)

plotshape(showDots and not na(ph), "Swing High", shape.circle, location.abovebar,
     color = color.new(color.red, 40), size = size.tiny, offset = -rightBars)
plotshape(showDots and not na(pl), "Swing Low", shape.circle, location.belowbar,
     color = color.new(color.green, 40), size = size.tiny, offset = -rightBars)

// ---------------- Track pivots + build per-bar signal flags ----------------
var float lastPHprice = na
var float lastPHmacd  = na
var int   lastPHbar   = na
var float lastPLprice = na
var float lastPLmacd  = na
var int   lastPLbar   = na

var bool bullSignal = false
var bool bearSignal = false
bullSignal := false
bearSignal := false

// Bearish divergence pivot
if not na(ph)
    phPrice = ph
    phMacd  = macdLine[rightBars]
    phBar   = bar_index - rightBars
    if not na(lastPHprice)
        higherHigh = phPrice > lastPHprice
        bearDiv    = higherHigh and phMacd < lastPHmacd
        span       = phBar - lastPHbar
        spanOK     = span >= spanMin and span <= spanMax
        v5_bear    = bearDiv and inDowntrend and spanOK
        scalpr_bear_gate = regimeStrong and bearContext
        if v5_bear and scalpr_bear_gate
            bearSignal := true
    lastPHprice := phPrice
    lastPHmacd  := phMacd
    lastPHbar   := phBar

// Bullish divergence pivot
if not na(pl)
    plPrice = pl
    plMacd  = macdLine[rightBars]
    plBar   = bar_index - rightBars
    if not na(lastPLprice)
        lowerLow = plPrice < lastPLprice
        bullDiv  = lowerLow and plMacd > lastPLmacd
        span     = plBar - lastPLbar
        spanOK   = span >= spanMin and span <= spanMax
        v5_bull  = bullDiv and inUptrend and spanOK
        scalpr_bull_gate = regimeStrong and bullContext
        if v5_bull and scalpr_bull_gate
            bullSignal := true
    lastPLprice := plPrice
    lastPLmacd  := plMacd
    lastPLbar   := plBar

// ---------------- Visual layers ----------------
plot(sma, "Trend 200-SMA", color = color.new(color.blue, 0), linewidth = 2)
plot(showEMAs ? ema9  : na, "EMA 9",  color = color.new(color.orange, 0), linewidth = 1)
plot(showEMAs ? ema21 : na, "EMA 21", color = color.new(color.purple, 0), linewidth = 1)

bgcolor(tintBg and inUptrend   ? color.new(color.green, 94) : na, title = "Uptrend regime")
bgcolor(tintBg and inDowntrend ? color.new(color.red,   94) : na, title = "Downtrend regime")

plotshape(bullSignal, "LONG entry", shape.triangleup, location.belowbar,
     color = color.new(color.green, 0), size = size.small, text = "LONG")
plotshape(bearSignal, "SHORT entry", shape.triangledown, location.abovebar,
     color = color.new(color.red, 0), size = size.small, text = "SHORT")

// ---------------- Strategy execution ----------------
if bullSignal and (exitOnOpp or strategy.position_size <= 0)
    strategy.entry("Long", strategy.long, comment = "V5+SCALPR bull")
    slPxL = close - slMult * atr
    tpPxL = close + tpMult * atr
    strategy.exit("Long-Exit", from_entry = "Long", stop = slPxL, limit = tpPxL)

if bearSignal and (exitOnOpp or strategy.position_size >= 0)
    strategy.entry("Short", strategy.short, comment = "V5+SCALPR bear")
    slPxS = close + slMult * atr
    tpPxS = close - tpMult * atr
    strategy.exit("Short-Exit", from_entry = "Short", stop = slPxS, limit = tpPxS)

// ---------------- Regime dashboard (bottom-right) ----------------
if showDash and barstate.islast
    trendTxt = inUptrend ? "UPTREND" : inDowntrend ? "DOWNTREND" : "FLAT"
    trendCol = inUptrend ? color.green : inDowntrend ? color.red : color.gray
    adxTxt = regimeStrong ? "STRONG (>=" + str.tostring(adxMin, "#.#") + ")" : "WEAK / RANGING"
    adxCol = regimeStrong ? color.green : color.orange
    emaTxt = bullContext ? "EMA9 > EMA21 (bull)" : bearContext ? "EMA9 < EMA21 (bear)" : "flat"
    emaCol = bullContext ? color.green : bearContext ? color.red : color.gray
    posTxt = strategy.position_size > 0 ? "LONG"  : strategy.position_size < 0 ? "SHORT" : "FLAT"
    posCol = strategy.position_size > 0 ? color.green : strategy.position_size < 0 ? color.red : color.gray

    var table dash = table.new(position.bottom_right, 2, 6, border_width = 1,
         bgcolor = color.new(#0a0e1a, 20), frame_color = color.new(color.blue, 60),
         frame_width = 1)
    table.cell(dash, 0, 0, "V5 + SCALPR", text_color = color.aqua, text_size = size.small,
         bgcolor = color.new(#0d1424, 0), text_halign = text.align_center)
    table.cell(dash, 1, 0, syminfo.ticker + " " + timeframe.period, text_color = color.gray,
         text_size = size.small, bgcolor = color.new(#0d1424, 0), text_halign = text.align_center)
    table.cell(dash, 0, 1, "TREND (200-SMA)", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 1, trendTxt, text_color = trendCol, text_size = size.small)
    table.cell(dash, 0, 2, "ADX (" + str.tostring(adxLen) + ")", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 2, str.tostring(math.round(adx)) + " " + adxTxt, text_color = adxCol, text_size = size.small)
    table.cell(dash, 0, 3, "EMA context", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 3, emaTxt, text_color = emaCol, text_size = size.small)
    table.cell(dash, 0, 4, "POSITION", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 4, posTxt, text_color = posCol, text_size = size.small)
    table.cell(dash, 0, 5, "R:R", text_color = color.gray, text_size = size.small)
    table.cell(dash, 1, 5, "1 : " + str.tostring(tpMult / slMult, "#.##"), text_color = color.aqua, text_size = size.small)

// ---------------- Alerts ----------------
alertcondition(bullSignal, "V5+SCALPR Long",
     "V5+SCALPR LONG on {{ticker}} @ {{close}}")
alertcondition(bearSignal, "V5+SCALPR Short",
     "V5+SCALPR SHORT on {{ticker}} @ {{close}}")
