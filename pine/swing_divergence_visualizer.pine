//@version=6
// =====================================================================
// Swing + MACD-Divergence VISUALIZER  v3 — with TREND ALIGNMENT
// Pine v6 · free plan.  Context tool, NOT a profit signal.
//
// EVIDENCE-BASED LABELLING (from this project's 15+ tests):
//   * Plain divergence had NO tradeable edge.
//   * Bar-span and volume-contraction filters did NOT rescue it.
//   * The ONLY factor with statistical robustness was TREND ALIGNMENT:
//     - Bullish divergence ABOVE the daily-equivalent 200-SMA (with trend)  -> "✓ ALIGNED"
//     - Bearish divergence BELOW the 200-SMA (with trend)                   -> "✓ ALIGNED"
//     - Anything counter-trend                                              -> "✗ FIGHTING TREND"
//   This is for CONTEXT — confluence with structure, not a standalone trigger.
//
// EARLIER CONFIRMATION (your earlier request): a pivot needs `rightBars` bars
// to the RIGHT to confirm. Default 2 (was 5) -> draws ~3 bars sooner.
// Trade-off: fewer right-bars = less reliable pivots (more get invalidated).
// 0 is impossible without repainting.
// =====================================================================
indicator("Swing + MACD Divergence v3 [+Trend Align]", overlay = true,
     max_lines_count = 500, max_labels_count = 500)

// ---------------- Inputs ----------------
g1 = "Pivot detection"
leftBars  = input.int(5, "LEFT bars (structure)",  minval = 2,  group = g1)
rightBars = input.int(2, "RIGHT bars (confirmation lag)", minval = 1, maxval = 5,
     group = g1,
     tooltip = "Lower = earlier/more predictive but less reliable. " +
               "0 is impossible without repainting.")

g2 = "MACD"
fastLen = input.int(12, "MACD fast",   group = g2)
slowLen = input.int(26, "MACD slow",   group = g2)
sigLen  = input.int(9,  "MACD signal", group = g2)

g3 = "Trend alignment (the only robust factor in testing)"
trendLen   = input.int(200, "Trend SMA length", minval = 50, group = g3)
hideUnaligned = input.bool(false, "Hide counter-trend divergences",
     group = g3, tooltip = "When ON, only divergences ALIGNED with the trend are drawn.")
tintBg     = input.bool(true, "Tint background by trend regime", group = g3)

g4 = "Display"
showDots  = input.bool(true, "Mark all swing pivots", group = g4)
showDiv   = input.bool(true, "Draw divergence lines", group = g4)
showNote  = input.bool(true, "Show on-chart legend",  group = g4)

// ---------------- Core series ----------------
[macdLine, _s, _h] = ta.macd(close, fastLen, slowLen, sigLen)
trendSMA = ta.sma(close, trendLen)
inUptrend   = close > trendSMA
inDowntrend = close < trendSMA

// ---------------- Pivots (non-repainting at the chosen rightBars) ----------------
ph = ta.pivothigh(high, leftBars, rightBars)
pl = ta.pivotlow(low,  leftBars, rightBars)

plotshape(showDots and not na(ph), title = "Swing High", style = shape.circle,
     location = location.abovebar, color = color.new(color.red, 40),
     size = size.tiny, offset = -rightBars)
plotshape(showDots and not na(pl), title = "Swing Low", style = shape.circle,
     location = location.belowbar, color = color.new(color.green, 40),
     size = size.tiny, offset = -rightBars)

// ---------------- Track most-recent pivot + run length ----------------
var float lastPHprice = na, var float lastPHmacd = na, var int lastPHbar = na, var int hhRun = 0
var float lastPLprice = na, var float lastPLmacd = na, var int lastPLbar = na, var int llRun = 0

// ===== Bearish divergence (price HH, MACD LH) =====
if not na(ph)
    phPrice = ph
    phMacd  = macdLine[rightBars]
    phBar   = bar_index - rightBars
    if not na(lastPHprice)
        higherHigh = phPrice > lastPHprice
        bearDiv    = higherHigh and phMacd < lastPHmacd
        hhRun     := higherHigh ? hhRun + 1 : 1
        if bearDiv and showDiv
            // Trend test: a BEARISH divergence is ALIGNED only in a downtrend.
            alignedBear = inDowntrend
            drawIt = alignedBear or (not hideUnaligned)
            if drawIt
                lineCol = alignedBear ? color.new(color.red, 0) : color.new(color.red, 70)
                line.new(lastPHbar, lastPHprice, phBar, phPrice,
                     color = lineCol, width = alignedBear ? 2 : 1,
                     style = alignedBear ? line.style_solid : line.style_dotted)
                tag = alignedBear ? "Bear Div  ✓ ALIGNED" : "Bear Div  ✗ vs uptrend"
                bgc = alignedBear ? color.new(color.red, 10) : color.new(color.gray, 50)
                label.new(phBar, phPrice,
                     tag + "\nHH run: " + str.tostring(hhRun),
                     style = label.style_label_down, color = bgc,
                     textcolor = color.white, size = size.small)
    else
        hhRun := 1
    lastPHprice := phPrice
    lastPHmacd  := phMacd
    lastPHbar   := phBar

// ===== Bullish divergence (price LL, MACD HL) =====
if not na(pl)
    plPrice = pl
    plMacd  = macdLine[rightBars]
    plBar   = bar_index - rightBars
    if not na(lastPLprice)
        lowerLow = plPrice < lastPLprice
        bullDiv  = lowerLow and plMacd > lastPLmacd
        llRun   := lowerLow ? llRun + 1 : 1
        if bullDiv and showDiv
            // Trend test: a BULLISH divergence is ALIGNED only in an uptrend.
            alignedBull = inUptrend
            drawIt = alignedBull or (not hideUnaligned)
            if drawIt
                lineCol = alignedBull ? color.new(color.green, 0) : color.new(color.green, 70)
                line.new(lastPLbar, lastPLprice, plBar, plPrice,
                     color = lineCol, width = alignedBull ? 2 : 1,
                     style = alignedBull ? line.style_solid : line.style_dotted)
                tag = alignedBull ? "Bull Div  ✓ ALIGNED" : "Bull Div  ✗ vs downtrend"
                bgc = alignedBull ? color.new(color.green, 10) : color.new(color.gray, 50)
                label.new(plBar, plPrice,
                     tag + "\nLL run: " + str.tostring(llRun),
                     style = label.style_label_up, color = bgc,
                     textcolor = color.white, size = size.small)
    else
        llRun := 1
    lastPLprice := plPrice
    lastPLmacd  := plMacd
    lastPLbar   := plBar

// ---------------- Trend SMA + regime tint ----------------
plot(trendSMA, "Trend SMA", color = color.new(color.blue, 0), linewidth = 1)
bgcolor(tintBg and inUptrend   ? color.new(color.green, 94) : na, title = "Uptrend regime")
bgcolor(tintBg and inDowntrend ? color.new(color.red,   94) : na, title = "Downtrend regime")

// ---------------- On-chart legend ----------------
if showNote and barstate.islast
    regime = inUptrend ? "UPTREND (above SMA)" :
       inDowntrend ? "DOWNTREND (below SMA)" : "FLAT"
    var table tb = table.new(position.bottom_right, 1, 1, border_width = 1)
    table.cell(tb, 0, 0,
         "VISUALIZER — context only.\nRegime: " + regime + "\n" +
         "✓ ALIGNED = divergence WITH the trend  (the only robust factor).\n" +
         "✗ FIGHTING = divergence AGAINST the trend (statistically a loser).\n" +
         "Confirms " + str.tostring(rightBars) + " bars after pivot " +
         "(lower = earlier, less firm).",
         text_color = color.white, bgcolor = color.new(color.maroon, 10),
         text_size = size.small, text_halign = text.align_left)

// ---------------- Alerts (only meaningful ones) ----------------
alertcondition(not na(ph) and inDowntrend, "Bearish div ALIGNED",
     "Bearish divergence in downtrend on {{ticker}} @ {{close}}")
alertcondition(not na(pl) and inUptrend,   "Bullish div ALIGNED",
     "Bullish divergence in uptrend on {{ticker}} @ {{close}}")
